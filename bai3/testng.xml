<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Bai3_DDT_Excel_Suite" parallel="false">

    <test name="Smoke Test">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="framework.tests.LoginDDTTest"/>
        </classes>
    </test>

    <test name="Regression Test">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="framework.tests.LoginDDTTest"/>
        </classes>
    </test>

</suite>